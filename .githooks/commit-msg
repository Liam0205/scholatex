#!/usr/bin/env bash
# commit-msg: enforce conventional commits 'type(scope): subject'.
#
# Skipped for Merge/Revert/fixup!/squash! auto-messages; short-circuits in CI.
set -euo pipefail

if [ -n "${CI:-}" ] || [ -n "${GITHUB_ACTIONS:-}" ]; then exit 0; fi

msg=$(head -1 "$1")

case "$msg" in
    Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

pattern='^(feat|fix|doc|docs|test|chore|perf|refactor|ci|bench|build|revert)(\([A-Za-z0-9/_., -]+\))?: .+'
if ! [[ "$msg" =~ $pattern ]]; then
    echo "✗ commit message does not match 'type(scope): subject':" >&2
    echo "    $msg" >&2
    echo "allowed types: feat fix doc docs test chore perf refactor ci bench build revert" >&2
    echo "example: feat(math): add Hadamard product to mathlite vocabulary" >&2
    echo "         docs(llmdoc): sync architecture diagram with current implementation" >&2
    exit 1
fi
