# TeX Live packages required to compile scholatex and run its test corpus.
#
# Format: one package name per line; blank lines and `# ` comments allowed.
# Consumed by .github/workflows/*.yml via setup-texlive-action's
# `package-file:` option, and hashed by hashFiles() so this list is part
# of the TL cache key.
#
# The list is derived from `lualatex --recorder` traces over every file
# in examples/*.tex. To regenerate after a cls dependency change:
#
#   cd /tmp && mkdir t && cd t
#   for f in <path-to-repo>/examples/*.tex; do
#     cp "$f" main.tex
#     TEXINPUTS=<path-to-repo>: LUAINPUTS=<path-to-repo>: \
#       lualatex --recorder -interaction=nonstopmode main.tex >/dev/null 2>&1
#     grep -oE 'INPUT [^ ]+\.(sty|cls|def|cfg|fd|tex|lua|cmap|clo)$' main.fls
#   done | awk '{print $2}' | grep -oE '/tex/[^/]+/[^/]+/' \
#        | sed -E 's|/tex/[^/]+/([^/]+)/|\1|' | sort -u

